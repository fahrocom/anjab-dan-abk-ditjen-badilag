{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "description": "Role: admin, editor, viewer" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User roles and profile information"
    }
  }
}
